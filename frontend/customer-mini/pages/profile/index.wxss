.page {
  padding: 24rpx;
}

.skeleton-wrap {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* ── Hero ── */

.hero {
  padding: 36rpx 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #0f766e, #14b8a6 60%, #99f6e4);
  color: #ffffff;
  box-shadow: 0 24rpx 60rpx rgba(15, 118, 110, 0.18);
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 20rpx;
}

.hero-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.hero-info {
  flex: 1;
}

.hero-name {
  font-size: 38rpx;
  font-weight: 700;
}

.hero-level {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.hero-store {
  width: 100%;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: -4rpx;
}

/* ── 统计行 ── */

.stats-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 20rpx;
}

.stat-item {
  padding: 24rpx 16rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.04);
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f766e;
}

.stat-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

/* ── 菜单区 ── */

.menu-section {
  margin-top: 24rpx;
}

.menu-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #94a3b8;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}

.menu-card {
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.04);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid #f8fafc;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.icon-order { background: #e0f2fe; color: #0ea5e9; }
.icon-order::after { content: "🧾"; }

.icon-ticket { background: #dbeafe; color: #3b82f6; }
.icon-ticket::after { content: "🎟️"; }

.icon-card { background: #fce7f3; color: #ec4899; }
.icon-card::after { content: "💳"; }

.icon-pet { background: #fef3c7; color: #d97706; }
.icon-pet::after { content: "🐾"; }

.menu-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #1e293b;
}

.menu-arrow {
  color: #cbd5e1;
  font-size: 28rpx;
}

/* ── 账号信息行 ── */

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f8fafc;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #64748b;
}

.info-value {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 500;
}

/* ── 版本号 ── */

.version {
  margin-top: 40rpx;
  text-align: center;
  font-size: 22rpx;
  color: #cbd5e1;
  padding-bottom: 20rpx;
}
