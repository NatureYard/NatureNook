.profile-page {
  padding-top: 24rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

.hero {
  padding: 0;
}

.level-pill {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 128, 90, 0.12);
  color: #ff7a57;
  font-size: 26rpx;
  font-weight: 600;
}

.section-title {
  margin: 32rpx 4rpx 16rpx;
  font-size: 36rpx;
  font-weight: 700;
}

.profile-card {
  margin-bottom: 16rpx;
  padding: 28rpx;
}

.item-title {
  font-size: 24rpx;
}

.item-value {
  margin-top: 12rpx;
  font-size: 36rpx;
  line-height: 1.5;
  font-weight: 600;
}
