.orders-page {
  padding-top: 24rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

.orders-hero {
  padding: 0;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 34rpx 4rpx 18rpx;
}

.section-head.secondary {
  margin-top: 38rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2f2a24;
}

.section-copy {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #8a7a6d;
}

.section-pill {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 131, 96, 0.12);
  color: #ff7f5f;
  font-size: 24rpx;
  font-weight: 600;
}

.pass-ticket {
  margin-bottom: 20rpx;
  padding: 30rpx;
  background:
    radial-gradient(circle at top right, rgba(137, 226, 203, 0.34), transparent 28%),
    linear-gradient(145deg, #ffffff 0%, #f4fffb 50%, #eefaf8 100%);
  border: 2rpx solid rgba(110, 202, 183, 0.24);
}

.pass-glow {
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(141, 222, 202, 0.22);
}

.ticket-head {
  position: relative;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.ticket-code {
  font-size: 24rpx;
  letter-spacing: 3rpx;
  color: #7db5a7;
}

.ticket-name {
  margin-top: 10rpx;
  font-size: 40rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #20534a;
}

.ticket-tone {
  position: relative;
  margin-top: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #2b7a6f;
}

.ticket-divider {
  position: relative;
  margin: 22rpx 0;
  border-top: 2rpx dashed rgba(73, 149, 132, 0.18);
}

.ticket-grid {
  position: relative;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.ticket-meta {
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.72);
}

.ticket-meta.full {
  grid-column: 1 / -1;
}

.ticket-label,
.order-amount-label {
  font-size: 24rpx;
  color: #87a097;
}

.ticket-value {
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #365d57;
}

.timeline {
  position: relative;
  padding-left: 28rpx;
}

.timeline::before {
  content: '';
  position: absolute;
  top: 18rpx;
  bottom: 18rpx;
  left: 8rpx;
  width: 4rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(255, 122, 89, 0.4), rgba(255, 196, 151, 0.18));
}

.order-item {
  margin-bottom: 20rpx;
  margin-left: 18rpx;
  padding: 28rpx;
}

.timeline-dot {
  position: absolute;
  top: 34rpx;
  left: -34rpx;
  width: 18rpx;
  height: 18rpx;
  border: 6rpx solid #fff3ea;
  border-radius: 50%;
  background: #ff845e;
  box-shadow: 0 0 0 8rpx rgba(255, 132, 94, 0.14);
}

.order-top,
.order-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.order-type {
  font-size: 34rpx;
  font-weight: 700;
}

.order-no {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.order-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.order-tone {
  font-size: 24rpx;
}

.order-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.order-chip {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #fff1e7;
  color: #b56a49;
  font-size: 24rpx;
}

.order-chip.light {
  background: #f6f8fb;
  color: #74808e;
}

.order-bottom {
  margin-top: 20rpx;
}

.order-amount {
  font-size: 38rpx;
  font-weight: 700;
  color: #ff7b58;
}

.badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.badge.paid {
  background: rgba(108, 209, 177, 0.16);
  color: #2a7a69;
}

.badge.pending {
  background: rgba(255, 196, 125, 0.2);
  color: #b46a21;
}

.empty-state {
  padding: 48rpx 32rpx;
  text-align: center;
}

.empty-state.warm {
  background: linear-gradient(145deg, #fffaf4 0%, #fff1e5 100%);
}

.empty-state.soft {
  background: linear-gradient(145deg, #ffffff 0%, #fff7f1 100%);
}

