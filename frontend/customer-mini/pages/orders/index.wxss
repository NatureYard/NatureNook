.page {
  padding: 24rpx;
}

/* ── Tab 筛选栏 ── */

.tab-bar {
  display: flex;
  gap: 8rpx;
  margin-bottom: 24rpx;
  padding: 6rpx;
  border-radius: 20rpx;
  background: #f1f5f9;
}

.tab-item {
  flex: 1;
  padding: 16rpx 0;
  border-radius: 16rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #64748b;
  transition: all 0.2s;
}

.tab-item.active {
  background: #ffffff;
  color: #0f766e;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* ── 骨架 ── */

.skeleton-wrap {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* ── 订单卡片 ── */

.order-card {
  position: relative;
  margin-bottom: 16rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.04);
  border-left: 6rpx solid transparent;
}

.order-card.today {
  border-left-color: #0f766e;
  background: #f0fdfa;
}

.order-badge {
  position: absolute;
  top: 0;
  right: 28rpx;
  padding: 6rpx 16rpx;
  border-radius: 0 0 12rpx 12rpx;
  background: #0f766e;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
}

.order-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-type {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.order-no {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #94a3b8;
  font-family: monospace;
}

.order-detail-row {
  display: flex;
  align-items: baseline;
  margin-top: 12rpx;
  gap: 12rpx;
}

.order-detail-label {
  font-size: 24rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.order-detail-value {
  font-size: 26rpx;
  color: #475569;
}

.order-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #f1f5f9;
}

.order-amount {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f766e;
}

.order-pass-btn {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: #0f766e;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
}
