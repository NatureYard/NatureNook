.page {
  padding: 24rpx;
}

.page-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #0f172a;
}

.page-subtitle {
  margin-top: 10rpx;
  margin-bottom: 24rpx;
  color: #64748b;
}

.section-title {
  margin: 32rpx 0 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.card {
  margin-bottom: 16rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.04);
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.name {
  font-size: 32rpx;
  font-weight: 700;
}

.desc,
.meta,
.amount {
  margin-top: 10rpx;
  color: #6b7280;
}

.pass-card {
  background: linear-gradient(135deg, #ecfeff 0%, #ffffff 100%);
  border: 2rpx solid #bae6fd;
}

.badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.badge.paid {
  background: #ccfbf1;
  color: #0f766e;
}

.badge.pending {
  background: #fef3c7;
  color: #b45309;
}

.empty-card {
  padding: 56rpx 32rpx;
  border-radius: 24rpx;
  background: #ffffff;
  color: #64748b;
  text-align: center;
}
