<view class="page">
  <view class="page-title">我的订单与入园凭证</view>
  <view class="page-subtitle">查看支付状态、预约信息和当前有效通行资格</view>

  <view wx:if="{{loading}}" class="empty-card">正在加载订单与凭证...</view>

  <block wx:elif="{{passes.length}}">
    <view class="section-title">当前有效凭证</view>
    <view wx:for="{{passes}}" wx:key="id" class="card pass-card">
      <view class="card-top">
        <view class="name">{{item.name}}</view>
        <view class="badge paid">{{item.status}}</view>
      </view>
      <view class="meta">{{item.storeName}}</view>
      <view class="meta">{{item.validWindow}}</view>
      <view class="meta">{{item.reentryPolicy}}</view>
    </view>
  </block>

  <view wx:elif="{{!orders.length}}" class="empty-card">
    当前还没有有效凭证
  </view>

  <view class="section-title">订单记录</view>

  <block wx:if="{{orders.length}}">
    <view wx:for="{{orders}}" wx:key="no" class="card">
      <view class="card-top">
        <view class="name">{{item.type}}</view>
        <view class="badge {{item.statusClass}}">{{item.status}}</view>
      </view>
      <view class="desc">{{item.no}}</view>
      <view class="meta">{{item.storeName}}</view>
      <view class="meta">{{item.reservationInfo}}</view>
      <view class="amount">金额：¥{{item.amount}}</view>
    </view>
  </block>

  <view wx:else class="empty-card">
    暂无订单记录
  </view>
</view>
