.cards-page {
  padding-top: 24rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

.cards-hero {
  padding: 0;
}

.membership-card {
  margin-top: 20rpx;
  padding: 30rpx;
}

.card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.badge,
.meta-pill {
  padding: 10rpx 18rpx;
  font-weight: 600;
}

.badge {
  background: rgba(255, 135, 94, 0.14);
  color: #ff7d59;
}

.name {
  margin-top: 16rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #2f2a24;
}

.price-block {
  text-align: right;
}

.price-label {
  font-size: 24rpx;
}

.price {
  margin-top: 10rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #ff7b57;
}

.desc {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #706255;
}

.meta-pill {
  margin-top: 18rpx;
}

.footnote {
  margin-top: 20rpx;
  font-size: 24rpx;
  line-height: 1.8;
}

.empty-state {
  margin-top: 20rpx;
}

