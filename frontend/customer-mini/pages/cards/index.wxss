.cards-page {
  padding-top: 24rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

.card-shell {
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 28rpx 70rpx rgba(214, 115, 85, 0.12);
}

.cards-hero {
  padding: 0;
}

.membership-card {
  margin-top: 20rpx;
  padding: 30rpx;
}

.membership-card.peach {
  background: linear-gradient(145deg, #fff7f0 0%, #fffdfb 100%);
}

.membership-card.mint {
  background: linear-gradient(145deg, #f0fffb 0%, #ffffff 100%);
}

.membership-card.sunset {
  background: linear-gradient(145deg, #fff0eb 0%, #fff8ed 100%);
}

.card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.badge,
.meta-pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.badge {
  background: rgba(255, 135, 94, 0.14);
  color: #ff7d59;
}

.name {
  margin-top: 16rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #2f2a24;
}

.price-block {
  text-align: right;
}

.price-label {
  font-size: 24rpx;
  color: #9a8777;
}

.price {
  margin-top: 10rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #ff7b57;
}

.desc {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #706255;
}

.meta-pill {
  margin-top: 18rpx;
  background: rgba(71, 182, 156, 0.12);
  color: #2e7f71;
}

.footnote {
  margin-top: 20rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #998677;
}

.empty-state {
  margin-top: 20rpx;
  padding: 56rpx 32rpx;
  text-align: center;
  color: #7d6d61;
}

