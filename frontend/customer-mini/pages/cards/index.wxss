.page {
  padding: 24rpx;
}

.skeleton-wrap {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* ── 卡片 ── */

.card-item {
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.06);
}

/* ── 卡头（渐变） ── */

.card-hero {
  padding: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #0f766e, #14b8a6);
}

.card-hero.inactive {
  background: linear-gradient(135deg, #64748b, #94a3b8);
}

.card-hero.pending {
  background: linear-gradient(135deg, #b45309, #f59e0b);
}

.card-hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-name {
  font-size: 36rpx;
  font-weight: 700;
}

.card-status {
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  font-size: 22rpx;
  font-weight: 600;
}

.card-price-row {
  margin-top: 12rpx;
}

.card-price-unit {
  font-size: 26rpx;
  opacity: 0.8;
}

.card-price-value {
  font-size: 44rpx;
  font-weight: 700;
  margin-left: 4rpx;
}

/* ── 卡身 ── */

.card-body {
  padding: 24rpx 28rpx 28rpx;
}

.card-desc {
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.6;
}

/* ── 有效期进度 ── */

.card-validity {
  margin-top: 20rpx;
  padding: 18rpx 0 0;
}

.validity-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.validity-label {
  font-size: 24rpx;
  color: #94a3b8;
}

.validity-remaining {
  font-size: 24rpx;
  font-weight: 600;
  color: #0f766e;
}

.validity-remaining.warning {
  color: #dc2626;
}

.progress-bar {
  height: 10rpx;
  border-radius: 5rpx;
  background: #e2e8f0;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 5rpx;
  background: linear-gradient(90deg, #0f766e, #14b8a6);
  transition: width 0.5s ease;
}

.progress-fill.warning {
  background: linear-gradient(90deg, #dc2626, #f87171);
}

/* ── 权益列表 ── */

.benefits {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #f1f5f9;
}

.benefits-title {
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 12rpx;
}

.benefits-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.benefit-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  color: #475569;
}

.benefit-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #14b8a6;
  flex-shrink: 0;
}
