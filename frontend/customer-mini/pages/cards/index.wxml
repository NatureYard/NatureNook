<view class="page cards-page page-stack">
  <view class="cards-hero card-shell page-hero rose">
    <view class="page-hero-top">
      <view class="status-pill soft">Membership Studio</view>
    </view>
    <view class="page-hero-copy">
      <view id="cards-page-title" class="page-hero-title">卡种中心</view>
      <view class="page-hero-text">{{summary}}</view>
    </view>
    <view class="page-status-panel">
      <view class="status-pill soft">辅助决策</view>
      <view class="page-status-note">{{decisionHint}}</view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="page-empty empty-state card-shell">
    <view class="status-pill soft">正在同步</view>
    <view class="page-empty-copy">正在为你整理卡种权益...</view>
  </view>

  <block wx:elif="{{cards.length}}">
    <view wx:for="{{cards}}" wx:key="id" id="membership-card-{{index}}" class="card-shell membership-card {{item.tone}}">
      <view class="card-top">
        <view>
          <view id="membership-card-badge-{{index}}" class="badge">{{item.badge}}</view>
          <view id="membership-card-name-{{index}}" class="name">{{item.name}}</view>
        </view>
        <view class="price-block">
          <view class="price-label">参考价格</view>
          <view id="membership-card-price-{{index}}" class="price">{{item.priceText}}</view>
        </view>
      </view>
      <view class="desc">{{item.desc}}</view>
      <view class="meta-pill">{{item.meta}}</view>
      <view class="footnote">适合希望把日常遛宠、周末游玩和固定训练节奏串起来的家庭。</view>
    </view>
  </block>

  <view wx:else class="page-empty empty-state card-shell">
    <view class="status-pill soft">暂无方案</view>
    <view class="page-empty-copy">暂无卡种信息</view>
  </view>
</view>
