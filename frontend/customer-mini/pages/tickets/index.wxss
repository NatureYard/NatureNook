.page {
  padding: 24rpx;
}

.page-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #0f172a;
}

.page-subtitle {
  margin-top: 10rpx;
  margin-bottom: 24rpx;
  color: #64748b;
}

.context-card,
.form-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.04);
}

.context-label,
.summary-label {
  font-size: 24rpx;
  color: #64748b;
}

.context-value {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.context-desc {
  margin-top: 10rpx;
  color: #0f766e;
}

.section-title {
  margin: 12rpx 0 18rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.card {
  margin-bottom: 16rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.04);
}

.card.selected {
  border: 2rpx solid #14b8a6;
}

.name {
  font-size: 32rpx;
  font-weight: 700;
}

.desc {
  margin-top: 10rpx;
  color: #6b7280;
}

.price {
  margin-top: 14rpx;
  color: #0f766e;
  font-size: 34rpx;
  font-weight: 700;
}

.card-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 14rpx;
}

.action {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  color: #0f172a;
  font-size: 24rpx;
  font-weight: 700;
}

.action.active {
  background: #0f766e;
  color: #ffffff;
}

.form-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.form-item {
  margin-top: 24rpx;
}

.form-label {
  font-size: 24rpx;
  color: #64748b;
}

.form-value,
.picker-value {
  margin-top: 10rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  color: #0f172a;
}

.form-value.muted {
  color: #64748b;
}

.summary-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #ecfeff;
}

.summary-price {
  margin-top: 8rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #0f766e;
}

.submit-btn {
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: #0f766e;
  color: #ffffff;
}

.empty-card {
  padding: 56rpx 32rpx;
  border-radius: 24rpx;
  background: #ffffff;
  color: #64748b;
  text-align: center;
}
