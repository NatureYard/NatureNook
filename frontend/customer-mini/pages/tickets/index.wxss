.page {
  padding-top: 28rpx;
  padding-left: 28rpx;
  padding-right: 28rpx;
}

.progress-strip {
  margin-bottom: 18rpx;
  padding: 24rpx 26rpx;
}

.progress-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.progress-caption {
  font-size: 24rpx;
}

.hero-shell {
  background: linear-gradient(135deg, #2f8f7d 0%, #74d0ab 100%);
  color: #1e544b;
  box-shadow: 0 24rpx 64rpx rgba(47, 143, 125, 0.22);
}

.hero-kicker,
.section-kicker {
  font-size: 26rpx;
  letter-spacing: 2rpx;
}

.hero-meta-card {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(244, 255, 251, 0.48);
}

.hero-meta-label,
.section-note,
.summary-label {
  font-size: 26rpx;
  color: rgba(30, 84, 75, 0.72);
}

.hero-meta-value {
  margin-top: 10rpx;
  font-size: 38rpx;
  font-weight: 700;
}

.hero-meta-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: rgba(30, 84, 75, 0.8);
}

.hero-price-panel {
  min-width: 180rpx;
  text-align: right;
}

.hero-price {
  margin-top: 10rpx;
  font-size: 50rpx;
  font-weight: 700;
}

.section-head {
  align-items: flex-end;
  margin-top: 28rpx;
}

.section-title {
  margin-top: 10rpx;
  color: #2e2a26;
}

.section-copy {
  max-width: 490rpx;
}

.card {
  margin-bottom: 16rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  box-shadow: 0 16rpx 48rpx rgba(53, 40, 31, 0.08);
}

.service-card {
  background: #ffffff;
}

.service-card.selected {
  border: 2rpx solid #ff7b58;
  box-shadow: 0 20rpx 56rpx rgba(255, 123, 88, 0.14);
}

.service-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.service-badge,
.service-action-tag,
.selection-badge {
  padding: 10rpx 16rpx;
  font-weight: 700;
}

.service-action-tag {
  background: rgba(46, 42, 38, 0.06);
  color: #7f7467;
}

.tone-sun .service-badge,
.tone-sun .selection-badge {
  background: rgba(217, 119, 6, 0.12);
  color: #d97706;
}

.tone-rose .service-badge,
.tone-rose .selection-badge {
  background: rgba(239, 91, 115, 0.12);
  color: #ef5b73;
}

.tone-mint .service-badge,
.tone-mint .selection-badge {
  background: rgba(15, 159, 127, 0.12);
  color: #0f9f7f;
}

.name {
  font-size: 34rpx;
  font-weight: 700;
  color: #2e2a26;
}

.desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #7f7467;
  line-height: 1.6;
}

.service-accent,
.selection-accent {
  margin-top: 16rpx;
  color: #f15f3b;
  font-size: 26rpx;
  font-weight: 700;
}

.price {
  margin-top: 14rpx;
  color: #2f8f7d;
  font-size: 38rpx;
  font-weight: 700;
}

.card-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
  padding: 18rpx 18rpx 18rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(242, 237, 232, 0.8);
}

.action {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #ff6b4a;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
}

.action.active {
  background: #0f766e;
}

.selection-card,
.form-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 48rpx rgba(53, 40, 31, 0.08);
}

.selection-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.selection-title {
  margin-top: 10rpx;
  font-size: 36rpx;
  font-weight: 700;
}

.selection-name {
  margin-top: 18rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #2e2a26;
}

.selection-desc,
.form-subtitle {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #7f7467;
  line-height: 1.6;
}

.form-title {
  font-size: 36rpx;
  font-weight: 700;
}

.inline-alert {
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: #fff5ef;
}

.inline-alert-copy {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #8e654f;
}

.form-item {
  margin-top: 24rpx;
}

.form-label {
  font-size: 26rpx;
}

.form-value,
.picker-value {
  margin-top: 10rpx;
  padding: 20rpx 24rpx;
  border-radius: 22rpx;
  background: #fff8f2;
  color: #2e2a26;
  font-size: 28rpx;
}

.form-value.muted {
  color: #8b7d6b;
}

.summary-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #fff0e7 0%, #fff9f4 100%);
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.summary-price {
  font-size: 42rpx;
  font-weight: 700;
  color: #f15f3b;
}

.summary-label {
}

.summary-caption {
  margin-top: 8rpx;
  font-size: 26rpx;
}

.submit-btn {
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff7b58 0%, #ff9966 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 40rpx rgba(255, 123, 88, 0.24);
}

.empty-card {
  padding: 56rpx 32rpx;
  border-radius: 24rpx;
  background: #ffffff;
  color: #8b7d6b;
  text-align: center;
  font-size: 28rpx;
}
