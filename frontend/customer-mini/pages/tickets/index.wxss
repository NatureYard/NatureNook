.page {
  padding: 24rpx 24rpx 160rpx;
}

/* ── 步骤指示器 ── */

.steps {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0 28rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.step-num {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #e2e8f0;
  color: #94a3b8;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.step.active .step-num {
  background: #0f766e;
  color: #ffffff;
}

.step-label {
  font-size: 22rpx;
  color: #94a3b8;
}

.step.active .step-label {
  color: #0f766e;
  font-weight: 600;
}

.step-line {
  width: 80rpx;
  height: 4rpx;
  background: #e2e8f0;
  margin: 0 12rpx;
  margin-bottom: 28rpx;
  border-radius: 2rpx;
  transition: all 0.3s;
}

.step-line.active {
  background: #0f766e;
}

/* ── 骨架 ── */

.skeleton-wrap {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 16rpx;
}

/* ── Step 1: 产品卡片 ── */

.product-card {
  margin-bottom: 16rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.04);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.product-card.selected {
  border-color: #14b8a6;
  background: #f0fdfa;
}

.product-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.product-tag {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #fef3c7;
  color: #b45309;
  font-size: 20rpx;
  font-weight: 600;
}

.product-desc {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.6;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
}

.product-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f766e;
}

.price-unit {
  font-size: 24rpx;
}

.product-check {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.product-check.checked {
  background: #0f766e;
  color: #ffffff;
}

/* ── Step 2: 表单 ── */

.warn-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #fffbeb;
  border: 1rpx solid #fde68a;
}

.warn-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #92400e;
}

.warn-desc {
  margin-top: 8rpx;
  color: #b45309;
  font-size: 26rpx;
}

.warn-btn {
  margin-top: 16rpx;
  padding: 16rpx 0;
  border-radius: 999rpx;
  background: #f59e0b;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
}

.form-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 8rpx 28rpx;
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.04);
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 12rpx;
}

.form-readonly {
  font-size: 30rpx;
  color: #0f172a;
  font-weight: 500;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  font-size: 28rpx;
  color: #0f172a;
}

.picker-arrow {
  color: #cbd5e1;
  font-size: 28rpx;
}

.form-empty {
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  background: #fef2f2;
  color: #dc2626;
  font-size: 28rpx;
  text-align: center;
}

/* ── 时段标签 ── */

.slot-grid {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.slot-tag {
  flex: 1;
  min-width: 180rpx;
  padding: 20rpx 16rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  color: #475569;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.slot-tag.active {
  background: #f0fdfa;
  color: #0f766e;
  border-color: #14b8a6;
}

/* ── Step 3: 确认卡片 ── */

.confirm-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.04);
}

.confirm-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 14rpx 0;
}

.confirm-label {
  color: #94a3b8;
  font-size: 26rpx;
  flex-shrink: 0;
}

.confirm-value {
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 500;
  text-align: right;
  margin-left: 24rpx;
}

.confirm-value.muted {
  color: #94a3b8;
  font-weight: 400;
}

.confirm-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
}

.confirm-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #0f766e;
}

/* ── 底部操作栏 ── */

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx calc(env(safe-area-inset-bottom) + 20rpx);
  background: #ffffff;
  box-shadow: 0 -8rpx 30rpx rgba(15, 23, 42, 0.06);
  z-index: 10;
}

.bottom-info {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.bottom-info .muted {
  color: #94a3b8;
  font-weight: 400;
}

.bottom-btn {
  flex-shrink: 0;
  min-width: 200rpx;
  padding: 22rpx 0;
  border-radius: 999rpx;
  background: #0f766e;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}

.bottom-btn[disabled] {
  background: #cbd5e1;
  color: #ffffff;
}

.bottom-btn.submit {
  flex: 1;
}

.bottom-btn-ghost {
  flex-shrink: 0;
  min-width: 160rpx;
  padding: 22rpx 0;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #475569;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}
