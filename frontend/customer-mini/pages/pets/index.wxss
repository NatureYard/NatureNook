.pets-page {
  padding-top: 24rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

.pets-hero {
  padding: 0;
}

.pet-grid {
  margin-top: 20rpx;
  display: grid;
  gap: 18rpx;
}

.pet-card {
  padding: 28rpx;
}

.pet-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #ff8d61 0%, #ffb35a 100%);
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
}

.pet-badge {
  margin-top: 18rpx;
  padding: 10rpx 18rpx;
  font-weight: 600;
}

.name {
  margin-top: 16rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #2f2a24;
}

.desc {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #726456;
}

.pet-note {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
}

.empty-state {
  margin-top: 20rpx;
}

