.page {
  padding: 24rpx;
}

.page-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #0f172a;
}

.page-subtitle {
  margin-top: 10rpx;
  margin-bottom: 24rpx;
  color: #64748b;
}

.card {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.04);
}

.pet-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #ccfbf1;
  color: #0f766e;
  font-size: 34rpx;
  font-weight: 700;
}

.pet-content {
  margin-left: 22rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 700;
}

.desc {
  margin-top: 10rpx;
  color: #6b7280;
}

.empty-card {
  padding: 56rpx 32rpx;
  border-radius: 24rpx;
  background: #ffffff;
  color: #64748b;
  text-align: center;
}
