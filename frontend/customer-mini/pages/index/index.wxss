.page {
  padding: 32rpx;
}

.hero {
  padding: 40rpx 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #0f766e, #14b8a6 55%, #99f6e4);
  color: #ffffff;
  box-shadow: 0 24rpx 60rpx rgba(15, 118, 110, 0.18);
}

.hero-top,
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-action,
.section-link {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 24rpx;
}

.hero-stats {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.hero-stat {
  flex: 1;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(7, 89, 83, 0.24);
}

.hero-stat-value {
  font-size: 36rpx;
  font-weight: 700;
}

.hero-stat-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.85);
}

.section {
  margin-top: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
}

.module-item {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.banner-item {
  margin-bottom: 16rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.04);
}

.banner-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #ccfbf1;
  color: #0f766e;
  font-size: 22rpx;
}

.banner-title {
  margin-top: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.module-item {
  min-height: 180rpx;
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.04);
}

.module-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.module-desc {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.5;
}

.tip-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #e7f7f2;
  color: #0f766e;
}

.tip-label {
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #0f766e;
  opacity: 0.72;
}
