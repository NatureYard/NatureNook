.page {
  padding: 32rpx;
}

.hero {
  padding: 40rpx 32rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #0f766e, #14b8a6);
  color: #ffffff;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.85);
}

.section {
  margin-top: 24rpx;
}

.section-title {
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.banner-item,
.module-item {
  margin-bottom: 16rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.tip-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #e7f7f2;
  color: #0f766e;
  font-weight: 700;
}
