.page {
  padding-top: 28rpx;
  padding-left: 28rpx;
  padding-right: 28rpx;
}

.hero-shell {
  background: linear-gradient(135deg, #ff8f6b 0%, #ffb36b 46%, #ffe3ae 100%);
  color: #5f3b29;
  box-shadow: 0 28rpx 70rpx rgba(255, 143, 107, 0.28);
}

.hero-orb {
  position: absolute;
  border-radius: 50%;
  opacity: 0.32;
  pointer-events: none;
}

.hero-orb-left {
  top: -36rpx;
  left: -40rpx;
  width: 180rpx;
  height: 180rpx;
  background: #ffd86f;
}

.hero-orb-right {
  right: -20rpx;
  bottom: 32rpx;
  width: 140rpx;
  height: 140rpx;
  background: #7ae1c1;
}

.section-head {
  align-items: center;
}

.hero-badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 241, 0.74);
  color: #ba643e;
  font-size: 26rpx;
  font-weight: 700;
}

.ghost-button,
.section-link {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
}

.ghost-button {
  background: rgba(255, 248, 241, 0.74);
  color: #8f563a;
}

.section-link {
  background: rgba(255, 139, 93, 0.12);
  color: #b26745;
}

.hero-kicker,
.section-kicker {
  font-size: 26rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.hero-kicker {
  color: rgba(95, 59, 41, 0.86);
}

.hero-action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.primary-button,
.secondary-button {
  flex: 1;
  padding: 22rpx 0;
  border-radius: 999rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
}

.primary-button {
  background: #ffffff;
  color: #f15f3b;
}

.secondary-button {
  background: rgba(255, 248, 241, 0.72);
  color: #8f563a;
}

.hero-status-row {
  background: rgba(255, 248, 241, 0.58);
}

.hero-status-pill {
  background: rgba(255, 139, 93, 0.14);
  color: #b0613f;
}

.hero-status-copy {
  color: rgba(95, 59, 41, 0.84);
}

.loading-panel {
  margin-top: 22rpx;
  padding: 28rpx;
}

.loading-title {
  margin-top: 16rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #2e2a26;
}

.section {
  margin-top: 28rpx;
}

.section-tight {
  margin-top: 22rpx;
}

.section-title {
  margin-top: 8rpx;
  color: #2e2a26;
}

.section-copy {
  max-width: 480rpx;
}

.banner-item {
  margin-bottom: 16rpx;
  padding: 28rpx 26rpx;
  border-radius: 28rpx;
  box-shadow: 0 18rpx 50rpx rgba(53, 40, 31, 0.08);
}

.banner-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.banner-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.banner-arrow {
  font-size: 34rpx;
  opacity: 0.5;
}

.banner-sun {
  background: linear-gradient(135deg, #fff3dc 0%, #fffaf0 100%);
}

.banner-sun .banner-tag,
.banner-sun .banner-arrow {
  color: #d97706;
  background: rgba(217, 119, 6, 0.12);
}

.banner-mint {
  background: linear-gradient(135deg, #ecfff7 0%, #f8fffc 100%);
}

.banner-mint .banner-tag,
.banner-mint .banner-arrow {
  color: #0f9f7f;
  background: rgba(15, 159, 127, 0.12);
}

.banner-rose {
  background: linear-gradient(135deg, #fff1ec 0%, #fff8f5 100%);
}

.banner-rose .banner-tag,
.banner-rose .banner-arrow {
  color: #ef5b73;
  background: rgba(239, 91, 115, 0.12);
}

.banner-title {
  margin-top: 16rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #2e2a26;
}

.banner-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #7f7467;
  line-height: 1.6;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.module-item {
  min-height: 228rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  box-shadow: 0 18rpx 52rpx rgba(53, 40, 31, 0.08);
}

.module-kicker {
  font-size: 24rpx;
  color: #9a8d7f;
}

.module-icon {
  margin-top: 16rpx;
  font-size: 42rpx;
}

.module-title {
  margin-top: 20rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #2e2a26;
}

.module-desc {
  margin-top: 12rpx;
  color: #7f7467;
  font-size: 26rpx;
  line-height: 1.5;
}

.module-link {
  margin-top: 18rpx;
  color: #f15f3b;
  font-size: 26rpx;
  font-weight: 700;
}

.tip-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #2f8f7d 0%, #61c5a4 100%);
  color: #ffffff;
  box-shadow: 0 20rpx 54rpx rgba(47, 143, 125, 0.18);
}

.tip-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.78);
}

.tip-title {
  margin-top: 12rpx;
  font-size: 38rpx;
  font-weight: 700;
}

.tip-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.92);
}
