.page {
  padding: 24rpx 24rpx 120rpx;
}

/* ── 骨架 ── */

.skeleton-wrap {
  padding: 8rpx 0;
}

/* ── Hero 卡片 ── */

.hero {
  position: relative;
  overflow: hidden;
  padding: 36rpx 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #0f766e, #14b8a6 55%, #bdffed);
  color: #ffffff;
  box-shadow: 0 24rpx 60rpx rgba(15, 118, 110, 0.22);
}

/* 带有奢华感的水印图形装饰 */
.hero::after {
  content: "";
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.25) 0%, rgba(255, 255, 255, 0) 100%);
  pointer-events: none;
}

.hero-top, .hero-stats {
  position: relative;
  z-index: 1;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.hero-name {
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.hero-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.hero-action {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  font-size: 24rpx;
  backdrop-filter: blur(8rpx);
}

.hero-stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.hero-stat {
  padding: 18rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(7, 89, 83, 0.24);
  text-align: center;
}

.hero-stat-value {
  font-size: 40rpx;
  font-weight: 800;
  font-family: "DIN", -apple-system, sans-serif;
}

.hero-stat-label {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
}

/* ── 今日入园提示 ── */

.today-pass {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 22rpx 28rpx;
  border-radius: 20rpx;
  background: #ecfdf5;
  border-left: 6rpx solid #0f766e;
}

.today-pass-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #0f766e;
  margin-right: 16rpx;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.today-pass-text {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #065f46;
}

.today-pass-arrow {
  font-size: 26rpx;
  color: #0f766e;
  font-weight: 700;
}

/* ── Section ── */

.section {
  margin-top: 28rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 16rpx;
}

.section-head .section-title {
  margin-bottom: 0;
}

/* ── Swiper 轮播 ── */

.banner-swiper {
  height: 200rpx;
  border-radius: 24rpx;
}

.banner-card {
  height: 100%;
  padding: 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #f0fdfa 0%, #ccfbf1 100%);
  box-sizing: border-box;
}

.banner-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #0f766e;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
}

.banner-title {
  margin-top: 14rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.banner-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.swiper-dots {
  display: flex;
  justify-content: center;
  gap: 10rpx;
  margin-top: 14rpx;
}

.swiper-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #cbd5e1;
  transition: all 0.3s;
}

.swiper-dot.active {
  width: 28rpx;
  border-radius: 6rpx;
  background: #0f766e;
}

/* ── 快捷入口 ── */

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.entry-item {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.04);
}

.entry-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.entry-icon--ticket { background: #dbeafe; color: #3b82f6; }
.entry-icon--ticket::after { content: "🎟️"; }

.entry-icon--card { background: #fce7f3; color: #ec4899; }
.entry-icon--card::after { content: "💳"; }

.entry-icon--paw { background: #fef3c7; color: #d97706; }
.entry-icon--paw::after { content: "🐾"; }

.entry-icon--pass { background: #d1fae5; color: #10b981; }
.entry-icon--pass::after { content: "✅"; }

.entry-icon--dot { background: #e5e7eb; color: #6b7280; }
.entry-icon--dot::after { content: "•"; }

.entry-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.entry-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

/* ── 提示卡片 ── */

.tip-card {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: #f0fdfa;
  border: 1rpx solid #ccfbf1;
}

.tip-label {
  font-size: 22rpx;
  color: #0f766e;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.6;
}

/* ── 浮动预约按钮 ── */

.fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(env(safe-area-inset-bottom) + 180rpx);
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0f766e, #14b8a6);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 40rpx rgba(15, 118, 110, 0.35);
  z-index: 10;
}

.fab-text {
  font-size: 26rpx;
  font-weight: 700;
}

/* ── 动画与通用交互属性 ── */

@keyframes fadeInMove {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in {
  animation: fadeInMove 0.65s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.opacity-80 {
  opacity: 0.8 !important;
  transition: opacity 0.15s ease;
}

.scale-98 {
  transform: scale(0.98) !important;
  transition: transform 0.15s ease;
}

.scale-95 {
  transform: scale(0.95) !important;
  transition: transform 0.15s ease;
}
