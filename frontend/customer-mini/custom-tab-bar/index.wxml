<view class="tab-shell">
  <view class="tab-backdrop"></view>
  <view class="tab-bar">
    <view
      wx:for="{{list}}"
      wx:key="pagePath"
      class="tab-item {{selected === index ? 'active' : ''}}"
      data-path="{{item.pagePath}}"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <view class="tab-icon-wrap">
        <view class="tab-dot"></view>
        <view class="tab-icon">{{item.icon}}</view>
      </view>
      <view class="tab-text">{{item.text}}</view>
      <view class="tab-caption">{{item.caption}}</view>
    </view>
  </view>
</view>